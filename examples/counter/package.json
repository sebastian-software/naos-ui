{
  "name": "@iktia/example-counter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "pnpm -w build:native && pnpm --filter @iktia/primitives build && pnpm prepare:dsd && vite build",
    "prepare:dsd": "node scripts/build-dsd-html.mjs",
    "test": "pnpm -w build:native && pnpm --filter @iktia/primitives build && pnpm prepare:dsd && playwright test",
    "type-check": "pnpm --filter @iktia/primitives build && tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@iktia/core": "workspace:^",
    "@iktia/primitives": "workspace:^",
    "@iktia/runtime": "workspace:^",
    "@iktia/vite": "workspace:^"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
