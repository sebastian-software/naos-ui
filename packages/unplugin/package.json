{
  "name": "@naos-ui/unplugin",
  "version": "1.0.0",
  "description": "Bundler-agnostic Naos component transform for Vite, Rollup, esbuild, webpack, and Rspack.",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sebastian-software/naos-ui.git",
    "directory": "packages/unplugin"
  },
  "bugs": "https://github.com/sebastian-software/naos-ui/issues",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "sideEffects": false,
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --globals src/*.test.ts"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@naos-ui/compiler": "workspace:^",
    "unplugin": "^2.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "esbuild": "^0.25.0",
    "rollup": "^4.30.0",
    "typescript": "^6.0.3",
    "tsdown": "0.22.3",
    "vitest": "^4.1.6"
  }
}
