{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "composite": true,
    "ignoreDeprecations": "6.0",
    "jsx": "react-jsx",
    "jsxImportSource": "lean-wc",
    "paths": {
      "lean-wc": ["src/index.ts"],
      "lean-wc/jsx-runtime": ["src/jsx-runtime.ts"],
      "lean-wc/runtime": ["src/runtime.ts"]
    },
    "rootDir": "src",
    "tsBuildInfoFile": "dist/tsconfig.tsbuildinfo"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
