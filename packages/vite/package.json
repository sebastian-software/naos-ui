{
  "name": "@naos-ui/vite",
  "version": "1.0.0",
  "description": "Vite plugin for compiling Naos native interface elements.",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sebastian-software/naos-ui.git",
    "directory": "packages/vite"
  },
  "bugs": "https://github.com/sebastian-software/naos-ui/issues",
  "exports": {
    ".": {
      "types": "./dist/vite.d.mts",
      "import": "./dist/vite.mjs",
      "require": "./dist/vite.cjs"
    }
  },
  "main": "./dist/vite.cjs",
  "module": "./dist/vite.mjs",
  "types": "./dist/vite.d.mts",
  "sideEffects": false,
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --globals src/*.test.ts"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@naos-ui/compiler": "workspace:^"
  },
  "peerDependencies": {
    "vite": "^6 || ^7 || ^8"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "typescript": "^6.0.3",
    "tsdown": "0.22.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.6"
  }
}
