{
  "name": "@naos-ui/compiler",
  "version": "1.1.0",
  "description": "Thin Node.js wrapper around the Naos native compiler.",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sebastian-software/naos-ui.git",
    "directory": "packages/compiler"
  },
  "bugs": "https://github.com/sebastian-software/naos-ui/issues",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "sideEffects": false,
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "check-native-types": "node ./scripts/generate-native-types.mjs --check",
    "generate-native-types": "node ./scripts/generate-native-types.mjs",
    "test": "vitest run --globals src/*.test.ts"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "optionalDependencies": {
    "@naos-ui/compiler-darwin-arm64": "workspace:^",
    "@naos-ui/compiler-darwin-x64": "workspace:^",
    "@naos-ui/compiler-linux-arm64-gnu": "workspace:^",
    "@naos-ui/compiler-linux-arm64-musl": "workspace:^",
    "@naos-ui/compiler-linux-x64-gnu": "workspace:^",
    "@naos-ui/compiler-linux-x64-musl": "workspace:^",
    "@naos-ui/compiler-win32-arm64-msvc": "workspace:^",
    "@naos-ui/compiler-win32-x64-msvc": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "typescript": "^6.0.3",
    "tsdown": "0.22.3",
    "vitest": "^4.1.6"
  }
}
