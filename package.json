{
  "name": "naos-workspace",
  "version": "1.0.0",
  "private": true,
  "description": "Rust/OXC-powered TSX compiler for Naos native interface elements.",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm -r --filter './packages/**' --if-present build",
    "build:docs": "pnpm --filter @naos-ui/docs build",
    "build:examples": "pnpm -r --filter './examples/**' --if-present build",
    "build:native": "cargo build -p naos-node && node scripts/copy-native-binding.mjs",
    "build:playground": "node scripts/build-playground-assets.mjs && pnpm --filter @naos-ui/playground-site build",
    "check-api-conventions": "node scripts/check-api-conventions.mjs",
    "check-dependency-boundaries": "oxlint -A correctness . && node scripts/check-dependency-boundaries.mjs",
    "check-release-set": "node scripts/check-release-set.mjs",
    "check:docs": "pnpm -r --filter './sites/**' --if-present type-check",
    "check-native-types": "pnpm --filter @naos-ui/compiler check-native-types",
    "check": "pnpm check-api-conventions && pnpm check-dependency-boundaries && pnpm check-release-set && pnpm check-types && pnpm check:docs && pnpm check:rust",
    "check-types": "pnpm build && pnpm -r --filter './packages/**' --if-present check-types",
    "check:rust": "cargo check --workspace",
    "lint": "pnpm lint:js && pnpm format:check && pnpm lint:rust",
    "lint:js": "oxlint --deny-warnings .",
    "lint:rust": "cargo clippy --all-targets --all-features -- -D warnings",
    "test": "pnpm test:repo && pnpm test:playground && pnpm test:packages && pnpm test:rust",
    "test:api-conventions": "node --test scripts/api-conventions.test.mjs",
    "test:dependency-boundaries": "node --test scripts/dependency-boundaries.test.mjs",
    "test:examples": "pnpm -r --filter './examples/**' --if-present test",
    "test:packages": "pnpm -r --filter './packages/**' --if-present test",
    "test:playground": "vitest run sites/playground/src/*.test.ts",
    "test:repo": "node --test scripts/release-set.test.mjs scripts/dependency-boundaries.test.mjs scripts/api-conventions.test.mjs",
    "test:rust": "cargo test --workspace",
    "verify:fresh-project": "node scripts/verify-fresh-project.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,mts,js,mjs,cjs}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,mts,js,mjs,cjs}\"",
    "fetch:native": "node scripts/fetch-native-binding.mjs",
    "check:js": "pnpm check-api-conventions && pnpm check-dependency-boundaries && pnpm check-release-set && pnpm check-native-types && pnpm check-types && pnpm check:docs"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "oxlint": "1.73.0",
    "prettier": "3.8.0",
    "tsdown": "0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
