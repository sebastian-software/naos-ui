{
  "name": "lean-wc-workspace",
  "private": true,
  "description": "Rust/OXC-powered TSX compiler for lean native Web Components.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm -r --filter './packages/**' --if-present build",
    "check": "pnpm check-types && pnpm check:rust",
    "check-types": "pnpm -r --filter './packages/**' --if-present check-types",
    "check:rust": "cargo check --workspace",
    "lint": "pnpm lint:rust",
    "lint:rust": "cargo clippy --all-targets --all-features -- -D warnings",
    "test": "pnpm -r --filter './packages/**' --if-present test && pnpm test:rust",
    "test:rust": "cargo test --workspace"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "typescript": "^6.0.3",
    "unbuild": "^3.6.1",
    "vitest": "^4.1.6"
  }
}
