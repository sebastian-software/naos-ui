{
  "name": "iktia-workspace",
  "private": true,
  "description": "Rust/OXC-powered TSX compiler for Iktia native interface elements.",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm -r --filter './packages/**' --if-present build",
    "build:examples": "pnpm -r --filter './examples/**' --if-present build",
    "build:native": "cargo build -p iktia-node && node scripts/copy-native-binding.mjs",
    "check-release-set": "node scripts/check-release-set.mjs",
    "check-native-types": "pnpm --filter @iktia/compiler check-native-types",
    "check": "pnpm check-release-set && pnpm check-types && pnpm check:rust",
    "check-types": "pnpm -r --filter './packages/**' --if-present check-types",
    "check:rust": "cargo check --workspace",
    "lint": "pnpm lint:rust",
    "lint:rust": "cargo clippy --all-targets --all-features -- -D warnings",
    "test": "pnpm -r --filter './packages/**' --if-present test && pnpm test:rust",
    "test:examples": "pnpm -r --filter './examples/**' --if-present test",
    "test:rust": "cargo test --workspace"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "typescript": "^6.0.3",
    "unbuild": "^3.6.1",
    "vitest": "^4.1.6"
  }
}
